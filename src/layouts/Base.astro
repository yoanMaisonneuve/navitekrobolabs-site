---
import Nav from '../components/Nav.astro';

interface Props {
	title: string;
	description: string;
	current: 'home' | 'build' | 'code' | 'demos' | 'journal';
	pageClass?: string;
}

const { title, description, current, pageClass = '' } = Astro.props;
const lastUpdated = '8 mai 2026';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#1a1a1a" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={`https://navitekrobolabs.com${Astro.url.pathname}`} />
		<meta name="twitter:card" content="summary" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class={pageClass}>
		<div class="scroll-progress" aria-hidden="true"></div>
		<canvas id="constellation" aria-hidden="true"></canvas>

		<Nav current={current} />

		<main>
			<slot />
		</main>

		<footer>
			<p class="status">Site en construction · v0 · Mis à jour le {lastUpdated}</p>
			<p class="links">
				<a href="https://github.com/yoanMaisonneuve" rel="me">GitHub</a> ·
				<a href="https://github.com/yoanMaisonneuve/navitekrobolabs-site">Source de ce site</a> ·
				<a href="mailto:ymaisonneuve@hotmail.com">Contact</a>
			</p>
		</footer>

		<script is:inline>
			// Constellation canvas (background)
			(function () {
				const canvas = document.getElementById('constellation');
				if (!canvas) return;
				const ctx = canvas.getContext('2d');
				let w, h, particles = [], dpr = Math.min(window.devicePixelRatio || 1, 2);
				let raf;
				const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				function resize() {
					w = window.innerWidth;
					h = window.innerHeight;
					canvas.width = w * dpr;
					canvas.height = h * dpr;
					canvas.style.width = w + 'px';
					canvas.style.height = h + 'px';
					ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
				}
				function init() {
					particles = [];
					const count = Math.min(90, Math.floor((w * h) / 18000));
					for (let i = 0; i < count; i++) {
						particles.push({
							x: Math.random() * w,
							y: Math.random() * h,
							vx: (Math.random() - 0.5) * 0.28,
							vy: (Math.random() - 0.5) * 0.28,
							r: Math.random() * 1.4 + 0.6,
						});
					}
				}
				function isDark() {
					return window.matchMedia('(prefers-color-scheme: dark)').matches;
				}
				function draw() {
					ctx.clearRect(0, 0, w, h);
					const baseRgb = isDark() ? '212, 176, 120' : '138, 109, 59';
					for (let i = 0; i < particles.length; i++) {
						const p = particles[i];
						p.x += p.vx;
						p.y += p.vy;
						if (p.x < 0 || p.x > w) p.vx = -p.vx;
						if (p.y < 0 || p.y > h) p.vy = -p.vy;
						ctx.beginPath();
						ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
						ctx.fillStyle = 'rgba(' + baseRgb + ', 0.85)';
						ctx.fill();
						for (let j = i + 1; j < particles.length; j++) {
							const q = particles[j];
							const dx = p.x - q.x;
							const dy = p.y - q.y;
							const d2 = dx * dx + dy * dy;
							const max = 160;
							if (d2 < max * max) {
								const d = Math.sqrt(d2);
								ctx.beginPath();
								ctx.moveTo(p.x, p.y);
								ctx.lineTo(q.x, q.y);
								ctx.strokeStyle = 'rgba(' + baseRgb + ', ' + (1 - d / max) * 0.32 + ')';
								ctx.lineWidth = 0.7;
								ctx.stroke();
							}
						}
					}
					raf = requestAnimationFrame(draw);
				}
				function start() {
					cancelAnimationFrame(raf);
					resize();
					init();
					if (reduced) {
						ctx.clearRect(0, 0, w, h);
						const baseRgb = isDark() ? '212, 176, 120' : '138, 109, 59';
						for (const p of particles) {
							ctx.beginPath();
							ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
							ctx.fillStyle = 'rgba(' + baseRgb + ', 0.85)';
							ctx.fill();
						}
					} else {
						draw();
					}
				}
				let resizeTimer;
				window.addEventListener('resize', () => {
					clearTimeout(resizeTimer);
					resizeTimer = setTimeout(start, 150);
				});
				start();
			})();

			// Fade-in au scroll (cibles génériques)
			(function () {
				const els = document.querySelectorAll('.fade-in');
				if (!('IntersectionObserver' in window)) {
					els.forEach((el) => el.classList.add('visible'));
					return;
				}
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((e) => {
							if (e.isIntersecting) {
								e.target.classList.add('visible');
								observer.unobserve(e.target);
							}
						});
					},
					{ threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
				);
				els.forEach((el) => observer.observe(el));
			})();

			// Reveal underline animé sur <em class="reveal">
			(function () {
				const els = document.querySelectorAll('em.reveal');
				if (!('IntersectionObserver' in window)) {
					els.forEach((el) => el.classList.add('drawn'));
					return;
				}
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((e) => {
							if (e.isIntersecting) {
								setTimeout(() => e.target.classList.add('drawn'), 220);
								observer.unobserve(e.target);
							}
						});
					},
					{ threshold: 0.6 }
				);
				els.forEach((el) => observer.observe(el));
			})();

			// Scroll progress bar
			(function () {
				const bar = document.querySelector('.scroll-progress');
				if (!bar) return;
				let ticking = false;
				function update() {
					const max = document.documentElement.scrollHeight - window.innerHeight;
					const pct = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
					bar.style.transform = 'scaleX(' + pct + ')';
					ticking = false;
				}
				function onScroll() {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				}
				window.addEventListener('scroll', onScroll, { passive: true });
				window.addEventListener('resize', onScroll);
				update();
			})();
		</script>

		<style is:global>
			:root {
				--c-ink: #1a1a1a;
				--c-paper: #fafaf7;
				--c-muted: #6b6b6b;
				--c-accent: #8a6d3b;
				--c-accent-bright: #b8884a;
				--c-rule: #e0ddd6;
				--c-card: rgba(255, 255, 255, 0.55);
				--c-card-border: rgba(138, 109, 59, 0.18);

				--serif:
					'Newsreader', 'Iowan Old Style', 'Palatino Linotype', 'Apple Garamond', 'Baskerville', 'Times New Roman',
					serif;
				--sans:
					'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
				--mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			}

			* {
				box-sizing: border-box;
			}
			html {
				background: var(--c-paper);
				scroll-behavior: smooth;
			}
			html,
			body {
				margin: 0;
				padding: 0;
				color: var(--c-ink);
				font-family: var(--sans);
				line-height: 1.65;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}
			body {
				background: transparent;
				position: relative;
			}

			#constellation {
				position: fixed;
				inset: 0;
				width: 100vw;
				height: 100vh;
				z-index: 0;
				pointer-events: none;
				opacity: 1;
			}
			.scroll-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 2px;
				background: var(--c-accent-bright);
				transform: scaleX(0);
				transform-origin: 0 0;
				z-index: 100;
				transition: transform 0.1s linear;
			}

			/* ---- NAV ---- */
			.site-nav {
				position: sticky;
				top: 0;
				z-index: 50;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1rem clamp(1.25rem, 4vw, 2rem);
				max-width: 1100px;
				margin: 0 auto;
				background: linear-gradient(to bottom, var(--c-paper) 60%, transparent);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
			}
			.nav-brand {
				font-family: var(--serif);
				font-size: 1.15rem;
				font-weight: 600;
				color: var(--c-ink);
				text-decoration: none;
				letter-spacing: -0.005em;
			}
			.nav-brand .dot {
				color: var(--c-accent);
				margin-left: 0.15em;
			}
			.nav-links {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				gap: clamp(0.85rem, 2.5vw, 1.75rem);
				align-items: center;
			}
			.nav-links a {
				color: var(--c-muted);
				text-decoration: none;
				font-size: 0.92rem;
				letter-spacing: 0.01em;
				transition: color 0.2s;
				position: relative;
			}
			.nav-links a:hover {
				color: var(--c-ink);
			}
			.nav-links a.active {
				color: var(--c-ink);
			}
			.nav-links a.active::after {
				content: '';
				position: absolute;
				left: 0;
				right: 0;
				bottom: -6px;
				height: 1.5px;
				background: var(--c-accent);
			}

			/* ---- MAIN ---- */
			main {
				position: relative;
				z-index: 1;
				max-width: 720px;
				margin: 0 auto;
				padding: clamp(1.5rem, 5vw, 4rem) clamp(1.25rem, 4vw, 2rem) clamp(2rem, 5vw, 4rem);
			}

			/* ---- TYPO ---- */
			h1.brand {
				font-family: var(--serif);
				font-size: clamp(1.85rem, 4.2vw, 2.6rem);
				font-weight: 600;
				letter-spacing: -0.01em;
				margin: 0 0 0.4rem;
			}
			.tagline {
				color: var(--c-muted);
				font-size: 0.875rem;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				margin: 0;
			}

			h2.page-title {
				font-family: var(--serif);
				font-size: clamp(2rem, 5vw, 2.75rem);
				font-weight: 600;
				letter-spacing: -0.015em;
				margin: 0 0 0.5rem;
				line-height: 1.15;
			}
			.page-subtitle {
				color: var(--c-muted);
				font-size: 1.05rem;
				margin: 0 0 2.5rem;
				font-style: italic;
			}

			article > h2 {
				font-family: var(--serif);
				font-size: clamp(2rem, 5vw, 2.75rem);
				font-weight: 600;
				letter-spacing: -0.015em;
				margin: 0 0 2rem;
				line-height: 1.15;
			}
			article > h2 .letter {
				display: inline-block;
				opacity: 0;
				transform: translateY(10px);
				transition:
					opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1),
					transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
				transition-delay: calc(var(--i) * 28ms);
			}
			article > h2.visible .letter {
				opacity: 1;
				transform: translateY(0);
			}

			article h3 {
				font-family: var(--serif);
				font-size: 1.4rem;
				font-weight: 600;
				margin: 3rem 0 0.75rem;
				letter-spacing: -0.005em;
			}

			article p {
				font-size: 1.0625rem;
				margin: 0 0 1.25rem;
			}
			.lede {
				font-size: 1.18rem;
				line-height: 1.55;
				font-weight: 400;
			}
			.dropcap::first-letter {
				font-family: var(--serif);
				font-size: 4em;
				float: left;
				line-height: 0.85;
				margin: 0.04em 0.12em -0.05em -0.04em;
				color: var(--c-accent);
				font-weight: 700;
				font-style: normal;
			}

			article strong {
				font-weight: 600;
				color: var(--c-ink);
				transition: color 0.2s ease;
			}
			article strong:hover {
				color: var(--c-accent);
			}

			em.reveal {
				font-style: normal;
				font-weight: 600;
				position: relative;
				display: inline-block;
				color: var(--c-ink);
			}
			em.reveal::after {
				content: '';
				position: absolute;
				left: 0;
				bottom: -2px;
				width: 100%;
				height: 2px;
				background: var(--c-accent);
				transform: scaleX(0);
				transform-origin: 0 50%;
				transition: transform 0.7s cubic-bezier(0.5, 0, 0.1, 1);
			}
			em.reveal.drawn::after {
				transform: scaleX(1);
			}

			/* ---- CARDS génériques ---- */
			.card {
				background: var(--c-card);
				border: 1px solid var(--c-card-border);
				border-radius: 8px;
				padding: 1.25rem 1.4rem;
				transition:
					transform 0.25s ease,
					border-color 0.25s ease,
					box-shadow 0.25s ease;
			}
			.card:hover {
				transform: translateY(-2px);
				border-color: var(--c-accent);
				box-shadow: 0 8px 24px -12px rgba(138, 109, 59, 0.25);
			}
			.card-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1rem;
				margin: 1.5rem 0 2.5rem;
			}

			.tag {
				display: inline-block;
				padding: 0.18em 0.55em;
				font-size: 0.72rem;
				font-weight: 500;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				border-radius: 999px;
				border: 1px solid var(--c-rule);
				color: var(--c-muted);
			}
			.tag.tag-ok {
				border-color: var(--c-accent);
				color: var(--c-accent);
			}
			.tag.tag-design {
				border-color: var(--c-rule);
				color: var(--c-muted);
			}
			.tag.tag-soon {
				border-color: var(--c-rule);
				color: var(--c-muted);
				font-style: italic;
			}

			a.button {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.55em 1.1em;
				background: var(--c-accent);
				color: var(--c-paper);
				text-decoration: none;
				border-radius: 6px;
				font-weight: 500;
				font-size: 0.92rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}
			a.button:hover {
				background: var(--c-accent-bright);
				transform: translateY(-1px);
			}
			a.button.button-ghost {
				background: transparent;
				color: var(--c-accent);
				border: 1px solid var(--c-accent);
			}
			a.button.button-ghost:hover {
				background: var(--c-accent);
				color: var(--c-paper);
			}
			a.button.button-disabled {
				background: var(--c-rule);
				color: var(--c-muted);
				cursor: not-allowed;
				pointer-events: none;
			}

			/* ---- FADE-IN générique ---- */
			.fade-in {
				opacity: 0;
				transform: translateY(20px);
				transition:
					opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1),
					transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
				will-change: opacity, transform;
			}
			.fade-in.visible {
				opacity: 1;
				transform: translateY(0);
			}

			/* ---- FOOTER ---- */
			footer {
				position: relative;
				z-index: 1;
				max-width: 1100px;
				margin: 0 auto;
				padding: 3rem clamp(1.25rem, 4vw, 2rem) 2rem;
				border-top: 1px solid var(--c-rule);
				color: var(--c-muted);
				font-size: 0.875rem;
				text-align: center;
			}
			footer p {
				margin: 0.25rem 0;
			}
			footer a {
				color: var(--c-accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s;
			}
			footer a:hover {
				border-bottom-color: var(--c-accent);
			}

			/* ---- ACCESSIBILITÉ ---- */
			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
				.fade-in {
					opacity: 1;
					transform: none;
					transition: none;
				}
				article > h2 .letter {
					opacity: 1;
					transform: none;
					transition: none;
				}
				.scroll-progress,
				em.reveal::after,
				.card {
					transition: none;
				}
			}

			@media (prefers-color-scheme: dark) {
				:root {
					--c-ink: #ededed;
					--c-paper: #0e0e10;
					--c-muted: #888888;
					--c-accent: #d4b078;
					--c-accent-bright: #e7c997;
					--c-rule: #26262a;
					--c-card: rgba(255, 255, 255, 0.03);
					--c-card-border: rgba(212, 176, 120, 0.18);
				}
				#constellation {
					opacity: 0.92;
				}
				.site-nav {
					background: linear-gradient(to bottom, var(--c-paper) 60%, transparent);
				}
			}
		</style>
	</body>
</html>
