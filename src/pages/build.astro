---
import Base from '../layouts/Base.astro';

interface Part {
	id: string;
	name: string;
	description: string;
	status: 'available' | 'design' | 'soon';
	statusLabel: string;
	stl?: string;
	source?: string;
	printTime?: string;
	material?: string;
	notes?: string;
}

const parts: Part[] = [
	{
		id: 'so-arm100',
		name: 'Bras SO-ARM100 (5 DoF)',
		description:
			"Le bras manipulateur 5 degrés de liberté du kit LeRobot HuggingFace. Validé en simulation MuJoCo dans le sprint cyborg-robotique-V1.0. Premier bras Navitek-compatible.",
		status: 'available',
		statusLabel: 'Disponible',
		stl: 'https://github.com/TheRobotStudio/SO-ARM100',
		source: 'https://huggingface.co/lerobot',
		printTime: '~32 h cumulées (PLA, 0.2 mm)',
		material: '~480 g PLA + 6 servos Buss + Raspberry Pi 5',
		notes: 'Adoption Navitek : firmware MotorPort + cerveau cyborg-loop. Version Navitek-wrapped à venir Q3 2026.',
	},
	{
		id: 'cerveau',
		name: 'Cerveau cyborg-loop',
		description:
			"Le module Python qui pilote le bras. Modèle linéaire baseline + champ directionnel matchllm + couche émotionnelle TOC + politique EFE Friston. 71 tests verts.",
		status: 'available',
		statusLabel: 'Open source',
		source: 'https://github.com/yoanMaisonneuve/dyad/tree/master/agents/cyborg-robotique-V1.0',
		notes: 'Le code est public dès aujourd\'hui. Documentation Navitek-formattée à venir.',
	},
	{
		id: 'bras-2dof',
		name: 'Bras 2 DoF jouet (validation)',
		description:
			"Bras planaire 2 degrés de liberté pour valider la stack cerveau avant le 5 DoF. Utilisé pour les démos pédagogiques fluide/danse.",
		status: 'design',
		statusLabel: 'Design Navitek Q3 2026',
		printTime: '~6 h estimé',
		material: '~120 g PLA + 2 servos MG996R',
		notes: 'STL custom Navitek en design. Pour l\'instant, scène MJCF dans le repo cyborg.',
	},
	{
		id: 'tete-capteurs',
		name: 'Tête + capteurs',
		description:
			"Caméra stéréo + microphones + IMU. Donne au robot la perception du monde réel. Premier organe perceptif de l'architecture cyborg.",
		status: 'design',
		statusLabel: 'Design Q4 2026',
		material: 'Caméras Pi NoIR + INMP441 + MPU-6050',
		notes: 'Pré-requis pour boucle PERCEPTION → MODELE → PREDICTION → ERREUR complète.',
	},
	{
		id: 'chassis',
		name: 'Châssis humanoïde',
		description: 'Squelette PLA + jonctions imprimables. Dimensionné pour s\'adapter à des servos grand public + Raspberry compute.',
		status: 'soon',
		statusLabel: 'Conception 2027',
		notes: '6 mois de R&D requis. La cinématique passe avant la mécanique — on mature le cerveau d\'abord.',
	},
	{
		id: 'locomotion',
		name: 'Base de locomotion',
		description: 'Module propulsion : 2 roues différentielles ou bipède. Choix dépend des résultats du sprint cinématique en cours.',
		status: 'soon',
		statusLabel: 'Conception 2027',
		notes: 'Tracking dans cyborg-robotique-V2.0 (à venir).',
	},
];
---

<Base
	title="Imprime ton robot — Navitek Robolabs"
	description="Imprime ton robot Navitek pièce par pièce. STL téléchargeables, instructions d'assemblage, statut de chaque organe. Open par construction."
	current="build"
>
	<header class="page-header fade-in">
		<h2 class="page-title">Imprime ton robot</h2>
		<p class="page-subtitle">Pièce par pièce, ouvert par construction.</p>
	</header>

	<section class="intro fade-in">
		<p>
			Navitek est un robot <em class="reveal">DIY-augmenté</em> : tu télécharges les STL, tu imprimes en PLA sur ton imprimante 3D
			grand public, tu visses les servos, tu flashes le cerveau. Le robot t'appartient.
		</p>
		<p>
			La liste ci-dessous est honnête. Certaines pièces sont disponibles maintenant (SO-ARM100, cerveau cyborg-loop). D'autres
			sont en design ou en R&D. Plutôt que prétendre que tout est prêt, on documente la trajectoire.
		</p>
	</section>

	<section class="prerequis fade-in">
		<h3>Pré-requis</h3>
		<ul>
			<li>Imprimante 3D (Ender-3 V3 SE ou équivalent — premier don externe au projet 2026-05-03)</li>
			<li>Filament PLA (1 kg pour démarrer, orange ou gris recommandés)</li>
			<li>Tournevis Phillips + clé Allen 2 mm</li>
			<li>Servos compatibles Buss (liste détaillée par pièce)</li>
			<li>Raspberry Pi 5 (4 ou 8 Go) pour le compute embarqué</li>
			<li>Patience et le pacte d'altruisme : tu construis pour toi et tu partages ce que tu apprends</li>
		</ul>
	</section>

	<section class="parts">
		<h3>Pièces du robot</h3>
		<div class="card-grid">
			{
				parts.map((p) => (
					<div class={`card part fade-in part-${p.status}`}>
						<div class="part-head">
							<h4>{p.name}</h4>
							<span class={`tag tag-${p.status === 'available' ? 'ok' : p.status === 'design' ? 'design' : 'soon'}`}>
								{p.statusLabel}
							</span>
						</div>
						<p class="part-desc">{p.description}</p>
						{p.printTime && (
							<p class="part-meta">
								<span>Temps d'impression :</span> {p.printTime}
							</p>
						)}
						{p.material && (
							<p class="part-meta">
								<span>Matériel :</span> {p.material}
							</p>
						)}
						{p.notes && <p class="part-notes">{p.notes}</p>}
						<div class="part-actions">
							{p.stl ? (
								<a href={p.stl} class="button" target="_blank" rel="noopener">
									Télécharger STL ↓
								</a>
							) : (
								<a class="button button-disabled" aria-disabled="true">
									STL bientôt
								</a>
							)}
							{p.source && (
								<a href={p.source} class="button button-ghost" target="_blank" rel="noopener">
									Code source ↗
								</a>
							)}
						</div>
					</div>
				))
			}
		</div>
	</section>

	<section class="contribute fade-in">
		<h3>Contribuer</h3>
		<p>
			Le pacte Navitek : <em class="reveal">ce que tu apprends en imprimant, tu le partages</em>. Soumets une issue ou pull
			request sur le repo si tu trouves un bug, améliores une pièce, documentes une variante (servo alternatif,
			matériau, calibration).
		</p>
		<div class="next-steps">
			<a href="https://github.com/yoanMaisonneuve/dyad/tree/master/agents/cyborg-robotique-V1.0" class="button" target="_blank" rel="noopener">
				Repo cyborg-robotique-V1.0 ↗
			</a>
			<a href="/code" class="button button-ghost">Tous les repos →</a>
		</div>
	</section>
</Base>

<style is:global>
	.page-header {
		margin-bottom: 2rem;
	}
	.intro,
	.prerequis,
	.parts,
	.contribute {
		margin-bottom: 2.5rem;
	}
	.intro p,
	.prerequis p,
	.contribute p {
		font-size: 1.0625rem;
		margin: 0 0 1rem;
	}

	.prerequis ul {
		padding-left: 1.2rem;
		margin: 0;
	}
	.prerequis li {
		margin: 0.45rem 0;
		color: var(--c-ink);
	}
	.prerequis li::marker {
		color: var(--c-accent);
	}

	.part h4 {
		font-family: var(--serif);
		font-size: 1.15rem;
		margin: 0;
		font-weight: 600;
		color: var(--c-ink);
		line-height: 1.3;
	}
	.part-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.75rem;
		margin-bottom: 0.6rem;
	}
	.part-desc {
		font-size: 0.95rem;
		color: var(--c-ink);
		margin: 0 0 0.85rem;
		line-height: 1.55;
	}
	.part-meta {
		font-size: 0.83rem;
		color: var(--c-muted);
		margin: 0.15rem 0;
	}
	.part-meta span {
		font-weight: 500;
		color: var(--c-ink);
	}
	.part-notes {
		font-size: 0.83rem;
		color: var(--c-muted);
		margin: 0.7rem 0 1rem;
		font-style: italic;
		padding-left: 0.7rem;
		border-left: 2px solid var(--c-rule);
	}
	.part-actions {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-top: 0.9rem;
	}
	.part-actions .button {
		font-size: 0.85rem;
		padding: 0.45em 0.95em;
	}

	.next-steps {
		display: flex;
		gap: 0.85rem;
		flex-wrap: wrap;
		margin-top: 1rem;
	}
</style>
