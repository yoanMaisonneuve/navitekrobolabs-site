---
import Base from '../layouts/Base.astro';

interface Demo {
	id: string;
	title: string;
	description: string;
	type: 'image' | 'video';
	url?: string;
	thumbnail?: string;
	source?: string;
	date: string;
	tags: string[];
}

const RAW = 'https://github.com/yoanMaisonneuve/dyad/raw/master/agents/cyborg-robotique-V1.0/viz/output';

const demos: Demo[] = [
	{
		id: 'so100-toc-vs-naive',
		title: 'SO-ARM100 5 DoF — Naïf vs TOC',
		description:
			"Comparaison side-by-side du bras SO-ARM100 piloté par un agent naïf vs un agent TOC (couche émotionnelle + flow). Gain mesuré : +0.467 sur le score flow.",
		type: 'video',
		url: `${RAW}/mujoco_so100_compare.mp4`,
		thumbnail: `${RAW}/mujoco_so100_compare_naive_thumb.png`,
		source: 'https://github.com/yoanMaisonneuve/dyad/blob/master/agents/cyborg-robotique-V1.0/viz/mujoco_so100_compare.py',
		date: '2026-05-06',
		tags: ['MuJoCo', 'SO-ARM100', 'flow'],
	},
	{
		id: 'so100-v6-demo',
		title: 'SO-ARM100 — Cerveau V6 cinématique apprise',
		description:
			"Démo du V6 MotorPort : le cerveau a appris la cinématique du bras à partir d'observations, pas via solveur IK explicite. Embodiment-agnostic.",
		type: 'video',
		url: `${RAW}/mujoco_so100_v6_demo.mp4`,
		source: 'https://github.com/yoanMaisonneuve/dyad/blob/master/agents/cyborg-robotique-V1.0/viz/mujoco_so100_v6_demo.py',
		date: '2026-05-06',
		tags: ['cinématique apprise', 'V6', 'MotorPort'],
	},
	{
		id: 'arm-2dof-personnalities',
		title: 'Bras 2 DoF — 5 personnalités, 5 trajectoires',
		description:
			"Le même bras avec 5 jeux de poids émotionnels différents (audacieux, prudent, ludique, perfectionniste, danse). Même cible, trajectoires radicalement différentes.",
		type: 'image',
		url: `${RAW}/personalities_grades.png`,
		date: '2026-05-06',
		tags: ['émotions', 'flow', 'TOC'],
	},
	{
		id: 'trajectory-3d',
		title: 'Trajectoires 3D end-effector',
		description:
			"Visualisation 3D des trajectoires de l'effecteur (position vs cible vs arc mid-chain). Politique EFE Friston sur 2 cibles pondérées.",
		type: 'image',
		url: `${RAW}/trajectories_3d.png`,
		date: '2026-05-06',
		tags: ['EFE', 'Friston', '3D'],
	},
	{
		id: 'flow-jerk',
		title: 'Métriques flow : jerk, courbure, re-planning',
		description:
			"Mesures objectives de la fluidité du mouvement. Plus le jerk est bas et la courbure constante, plus le geste est dansé.",
		type: 'image',
		url: `${RAW}/jerk_distribution.png`,
		date: '2026-05-06',
		tags: ['flow', 'métriques', 'jerk'],
	},
	{
		id: 'mujoco-2dof-toc',
		title: 'Bras 2 DoF MuJoCo — Comparaison naïf vs TOC',
		description: "Première preuve visuelle MuJoCo : le même bras, deux personnalités, deux gestes différents.",
		type: 'video',
		url: `${RAW}/mujoco_compare.mp4`,
		source: 'https://github.com/yoanMaisonneuve/dyad/blob/master/agents/cyborg-robotique-V1.0/viz/mujoco_compare.py',
		date: '2026-05-06',
		tags: ['MuJoCo', '2DoF', 'TOC'],
	},
];
---

<Base
	title="Démos — Navitek Robolabs"
	description="Démos visuelles du cerveau cyborg-loop : simulations MuJoCo, trajectoires 3D, métriques flow. Preuves que l'intelligence physique fonctionne."
	current="demos"
>
	<header class="page-header fade-in">
		<h2 class="page-title">Démos</h2>
		<p class="page-subtitle">Le cerveau en action. Chaque démo est rejouable depuis le code.</p>
	</header>

	<section class="intro fade-in">
		<p>
			Les démos ci-dessous viennent du sprint cyborg-robotique-V1.0 (avril-mai 2026). Elles prouvent que le cerveau
			cyborg-loop produit des comportements <em class="reveal">mesurablement différents</em> selon les poids
			émotionnels et la politique d'inférence active. Pas du marketing — du code rejouable.
		</p>
		<p>
			Chaque vidéo / image est hébergée dans le repo public <a href="https://github.com/yoanMaisonneuve/dyad" target="_blank" rel="noopener">dyad</a>.
			Cliques sur le lien <strong>Code source</strong> de chaque démo pour reproduire.
		</p>
	</section>

	<section class="demos">
		<div class="card-grid demos-grid">
			{
				demos.map((d) => (
					<div class="card demo-card fade-in">
						{d.type === 'video' ? (
							<div class="demo-media">
								<video
									controls
									preload="metadata"
									poster={d.thumbnail}
									src={d.url}
									aria-label={d.title}
								/>
							</div>
						) : (
							<a href={d.url} target="_blank" rel="noopener" class="demo-media demo-image">
								<img src={d.url} alt={d.title} loading="lazy" />
							</a>
						)}
						<div class="demo-body">
							<h4>{d.title}</h4>
							<p class="demo-desc">{d.description}</p>
							<div class="demo-meta">
								<span class="demo-date">{d.date}</span>
								<div class="demo-tags">
									{d.tags.map((t) => (
										<span class="demo-tag">{t}</span>
									))}
								</div>
							</div>
							{d.source && (
								<a href={d.source} class="demo-source" target="_blank" rel="noopener">
									Code source ↗
								</a>
							)}
						</div>
					</div>
				))
			}
		</div>
	</section>

	<section class="more fade-in">
		<h3>Plus de démos</h3>
		<p>
			Le dossier <a href="https://github.com/yoanMaisonneuve/dyad/tree/master/agents/cyborg-robotique-V1.0/viz/output" target="_blank" rel="noopener"><code>viz/output/</code></a>
			contient 40 fichiers de preuves visuelles. Les démos ci-dessus sont une sélection. Pour rejouer une démo localement :
		</p>
		<pre><code>git clone https://github.com/yoanMaisonneuve/dyad
cd dyad/agents/cyborg-robotique-V1.0
pip install -r requirements.txt
python viz/mujoco_so100_compare.py</code></pre>
	</section>
</Base>

<style is:global>
	.demos-grid {
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
	}
	.demo-card {
		display: flex;
		flex-direction: column;
		padding: 0;
		overflow: hidden;
	}
	.demo-media {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 10;
		background: var(--c-rule);
		overflow: hidden;
	}
	.demo-media video,
	.demo-media img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.demo-image {
		text-decoration: none;
	}
	.demo-body {
		padding: 1.1rem 1.25rem 1.25rem;
	}
	.demo-card h4 {
		font-family: var(--serif);
		font-size: 1.1rem;
		margin: 0 0 0.5rem;
		font-weight: 600;
		line-height: 1.3;
	}
	.demo-desc {
		font-size: 0.92rem;
		color: var(--c-ink);
		margin: 0 0 0.85rem;
		line-height: 1.5;
	}
	.demo-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.6rem;
		flex-wrap: wrap;
	}
	.demo-date {
		font-family: var(--mono);
		font-size: 0.78rem;
		color: var(--c-muted);
	}
	.demo-tags {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
	}
	.demo-tag {
		font-size: 0.72rem;
		color: var(--c-muted);
		background: var(--c-card);
		border: 1px solid var(--c-card-border);
		padding: 0.1em 0.55em;
		border-radius: 999px;
	}
	.demo-source {
		display: inline-block;
		font-size: 0.85rem;
		color: var(--c-accent);
		text-decoration: none;
	}
	.demo-source:hover {
		text-decoration: underline;
	}

	.more pre {
		font-family: var(--mono);
		background: var(--c-card);
		border: 1px solid var(--c-card-border);
		border-radius: 6px;
		padding: 1rem 1.25rem;
		font-size: 0.85rem;
		overflow-x: auto;
		line-height: 1.55;
		color: var(--c-ink);
	}
	.more code {
		font-family: var(--mono);
		font-size: 0.92em;
	}
</style>
