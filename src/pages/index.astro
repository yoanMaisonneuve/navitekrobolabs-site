	<body>
		<div class="scroll-progress" aria-hidden="true"></div>
		<canvas id="constellation" aria-hidden="true"></canvas>

		<main>
			<header>
				<h1 class="brand">Navitek Robolabs</h1>
				<p class="tagline">Physical AI · Made on Earth</p>
			</header>

			<article>
				<h2>Pourquoi Navitek</h2>

				<p class="lede">
					<strong>La robotique est un protocole de paix programmé.</strong> Le monde aura besoin de dix fois l'énergie actuelle,
					et nous ne construirons pas tous des réacteurs à fission. Mais nous pouvons construire des robots qui automatisent
					nos besoins fondamentaux — l'alimentation, la construction, la production — et libèrent le temps et l'énergie
					humaine pour autre chose.
				</p>

				<p class="lede">C'est ce que fait Navitek.</p>

				<section>
					<h3>Physical AI, pas IA logicielle</h3>
					<p>
						Le futur de l'intelligence artificielle ne sera pas qu'un texte sur un écran. Il sera <strong>incarné</strong> —
						des corps qui marchent, soulèvent, cultivent, assemblent. Navitek construit cette intelligence physique : l'IA qui
						agit dans le monde réel, pas qui le commente.
					</p>
				</section>

				<section>
					<h3>Automatiser les besoins, pas l'humain</h3>
					<p>
						Le robot Navitek cultive, transforme, soulève, assemble. Il fait ce qui demande de l'effort répétitif pour qu'on
						garde notre temps pour ce qui demande du sens : créer, transmettre, élever.
					</p>
				</section>

				<section>
					<h3>Une intelligence qui collabore</h3>
					<p>
						Le cerveau du robot Navitek n'est pas un cerveau qui prend le contrôle. C'est un cerveau <strong>élevé</strong>,
						qui apprend en boucle avec son humain. L'humain garde l'agentivité. Le robot exécute. Ensemble ils forment une
						équipe augmentée.
					</p>
				</section>

				<section>
					<h3>Un robot qui s'hérite</h3>
					<p>
						Nous ne construisons pas une boîte noire à louer. Nous construisons un robot
						<strong>réparable, modifiable, héritable</strong>. Vous pouvez l'ouvrir. Vous pouvez le modifier. Vous pouvez le
						léguer à vos enfants. Le savoir-faire ne meurt pas avec l'entreprise.
					</p>
				</section>

				<section>
					<h3>Pour qu'ils n'aient pas à être seuls</h3>
					<p>
						Je construis Navitek pour ma femme et mes trois enfants. Pour qu'ils grandissent dans un monde où des outils
						cognitifs et physiques les accompagnent à leur hauteur. C'est un héritage anticipé. Le pourquoi qui ne change
						pas.
					</p>
				</section>

				<section>
					<h3>Cap : 2126, le système solaire</h3>
					<p>
						Premier prototype au Québec en 2026. Usines pilotes en 2030. Cent millions d'unités par an en 2050. Présence
						dans le système solaire en 2126.
					</p>
					<p>Nous préparons le terrain. Nous commençons aujourd'hui, à un robot près.</p>
				</section>

				<p class="signature">— <strong>Yoan Maisonneuve</strong>, fondateur</p>
			</article>

			<footer>
				<p class="status">Site en construction · v0 · Mis à jour le {lastUpdated}</p>
				<p class="links">
					<a href="https://github.com/yoanMaisonneuve" rel="me">GitHub</a> ·
					<a href="mailto:ymaisonneuve@hotmail.com">Contact</a>
				</p>
			</footer>
		</main>

		<script is:inline>
			// Constellation canvas — points dérivants + liens entre proches
			(function () {
				const canvas = document.getElementById('constellation');
				if (!canvas) return;
				const ctx = canvas.getContext('2d');
				let w, h, particles = [], dpr = Math.min(window.devicePixelRatio || 1, 2);
				let raf;

				const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				function resize() {
					w = window.innerWidth;
					h = window.innerHeight;
					canvas.width = w * dpr;
					canvas.height = h * dpr;
					canvas.style.width = w + 'px';
					canvas.style.height = h + 'px';
					ctx.scale(dpr, dpr);
				}

				function init() {
					particles = [];
					const count = Math.min(90, Math.floor((w * h) / 18000));
					for (let i = 0; i < count; i++) {
						particles.push({
							x: Math.random() * w,
							y: Math.random() * h,
							vx: (Math.random() - 0.5) * 0.18,
							vy: (Math.random() - 0.5) * 0.18,
							r: Math.random() * 1.3 + 0.5,
						});
					}
				}

				function isDark() {
					return window.matchMedia('(prefers-color-scheme: dark)').matches;
				}

				function draw() {
					ctx.clearRect(0, 0, w, h);
					const baseRgb = isDark() ? '212, 176, 120' : '138, 109, 59';

					for (let i = 0; i < particles.length; i++) {
						const p = particles[i];
						p.x += p.vx;
						p.y += p.vy;
						if (p.x < 0 || p.x > w) p.vx = -p.vx;
						if (p.y < 0 || p.y > h) p.vy = -p.vy;

						ctx.beginPath();
						ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
						ctx.fillStyle = 'rgba(' + baseRgb + ', 0.55)';
						ctx.fill();

						for (let j = i + 1; j < particles.length; j++) {
							const q = particles[j];
							const dx = p.x - q.x;
							const dy = p.y - q.y;
							const d2 = dx * dx + dy * dy;
							const max = 145;
							if (d2 < max * max) {
								const d = Math.sqrt(d2);
								ctx.beginPath();
								ctx.moveTo(p.x, p.y);
								ctx.lineTo(q.x, q.y);
								ctx.strokeStyle = 'rgba(' + baseRgb + ', ' + (1 - d / max) * 0.18 + ')';
								ctx.lineWidth = 0.6;
								ctx.stroke();
							}
						}
					}

					raf = requestAnimationFrame(draw);
				}

				function start() {
					cancelAnimationFrame(raf);
					resize();
					init();
					if (reduced) {
						// rendu statique unique pour utilisateurs prefers-reduced-motion
						ctx.clearRect(0, 0, w, h);
						const baseRgb = isDark() ? '212, 176, 120' : '138, 109, 59';
						for (const p of particles) {
							ctx.beginPath();
							ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
							ctx.fillStyle = 'rgba(' + baseRgb + ', 0.55)';
							ctx.fill();
						}
					} else {
						draw();
					}
				}

				let resizeTimer;
				window.addEventListener('resize', () => {
					clearTimeout(resizeTimer);
					resizeTimer = setTimeout(start, 150);
				});
				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {});
				start();
			})();

			// Fade-in au scroll (Intersection Observer)
			(function () {
				const els = document.querySelectorAll(
					'article > h2, article > p.lede, article > section, article > p.signature, footer'
				);
				if (!('IntersectionObserver' in window)) {
					els.forEach((el) => el.classList.add('visible'));
					return;
				}
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((e) => {
							if (e.isIntersecting) {
								e.target.classList.add('visible');
								observer.unobserve(e.target);
							}
						});
					},
					{ threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
				);
				els.forEach((el) => observer.observe(el));
			})();

			// Scroll progress bar
			(function () {
				const bar = document.querySelector('.scroll-progress');
				if (!bar) return;
				let ticking = false;
				function update() {
					const max = document.documentElement.scrollHeight - window.innerHeight;
					const pct = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
					bar.style.transform = 'scaleX(' + pct + ')';
					ticking = false;
				}
				function onScroll() {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				}
				window.addEventListener('scroll', onScroll, { passive: true });
				window.addEventListener('resize', onScroll);
				update();
			})();
		</script>

		<style is:global>
			:root {
				--c-ink: #1a1a1a;
				--c-paper: #fafaf7;
				--c-muted: #6b6b6b;
				--c-accent: #8a6d3b;
				--c-rule: #e0ddd6;

				--serif:
					'Newsreader', 'Iowan Old Style', 'Palatino Linotype', 'Apple Garamond', 'Baskerville', 'Times New Roman',
					serif;
				--sans:
					'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--c-paper);
			}

			html,
			body {
				margin: 0;
				padding: 0;
				color: var(--c-ink);
				font-family: var(--sans);
				line-height: 1.65;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			body {
				background: transparent;
				position: relative;
			}

			#constellation {
				position: fixed;
				inset: 0;
				width: 100vw;
				height: 100vh;
				z-index: 0;
				pointer-events: none;
				opacity: 0.85;
			}

			.scroll-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 2px;
				background: var(--c-accent);
				transform: scaleX(0);
				transform-origin: 0 0;
				z-index: 100;
				transition: transform 0.12s linear;
			}

			main {
				position: relative;
				z-index: 1;
				max-width: 720px;
				margin: 0 auto;
				padding: clamp(2rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2rem);
			}

			header {
				margin-bottom: clamp(3rem, 8vw, 5rem);
				border-bottom: 1px solid var(--c-rule);
				padding-bottom: 2rem;
				animation: rise 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
			}

			.brand {
				font-family: var(--serif);
				font-size: clamp(1.75rem, 4vw, 2.5rem);
				font-weight: 600;
				letter-spacing: -0.01em;
				margin: 0 0 0.4rem;
			}

			.tagline {
				color: var(--c-muted);
				font-size: 0.875rem;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				margin: 0;
			}

			article h2 {
				font-family: var(--serif);
				font-size: clamp(2rem, 5vw, 2.75rem);
				font-weight: 600;
				letter-spacing: -0.015em;
				margin: 0 0 2rem;
				line-height: 1.15;
			}

			article h3 {
				font-family: var(--serif);
				font-size: 1.4rem;
				font-weight: 600;
				margin: 3rem 0 0.75rem;
				letter-spacing: -0.005em;
			}

			article p {
				font-size: 1.0625rem;
				margin: 0 0 1.25rem;
			}

			.lede {
				font-size: 1.18rem;
				line-height: 1.55;
				font-weight: 400;
			}

			article strong {
				font-weight: 600;
				color: var(--c-ink);
				transition: color 0.2s ease;
			}

			article strong:hover {
				color: var(--c-accent);
			}

			.signature {
				margin-top: 4rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--c-rule);
				color: var(--c-muted);
			}

			.signature strong {
				color: var(--c-ink);
			}

			footer {
				margin-top: clamp(4rem, 8vw, 6rem);
				padding-top: 2rem;
				border-top: 1px solid var(--c-rule);
				color: var(--c-muted);
				font-size: 0.875rem;
			}

			footer p {
				margin: 0.25rem 0;
			}

			footer a {
				color: var(--c-accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s;
			}

			footer a:hover {
				border-bottom-color: var(--c-accent);
			}

			/* Fade-in at scroll */
			article > h2,
			article > p.lede,
			article > section,
			article > p.signature,
			footer {
				opacity: 0;
				transform: translateY(24px);
				transition:
					opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
					transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
				will-change: opacity, transform;
			}

			article > h2.visible,
			article > p.lede.visible,
			article > section.visible,
			article > p.signature.visible,
			footer.visible {
				opacity: 1;
				transform: translateY(0);
			}

			/* Header animation initial */
			@keyframes rise {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* Reduced motion respect */
			@media (prefers-reduced-motion: reduce) {
				article > h2,
				article > p.lede,
				article > section,
				article > p.signature,
				footer {
					opacity: 1;
					transform: none;
					transition: none;
				}
				header {
					animation: none;
				}
				.scroll-progress {
					transition: none;
				}
			}

			@media (prefers-color-scheme: dark) {
				:root {
					--c-ink: #ededed;
					--c-paper: #0e0e10;
					--c-muted: #888888;
					--c-accent: #d4b078;
					--c-rule: #26262a;
				}
				#constellation {
					opacity: 0.7;
				}
			}
		</style>
	</body>
</html>
